# Home Assistant should not track these
home-assistant_v2.db*
*.db-shm
*.db-wal
.core/
.storage/
.cloud/
deps/
tts/
Git Clones/
secrets.yaml
.vscode/
.idea/

# Home Assistant runtime/local state
.HA_VERSION
.ha_build_info
.shopping_list.json
known_devices.yaml
zigbee.db*
ha_github
ha_github.pub

# Home Assistant logs and cache
home-assistant.log*
image/
media/

# HACS generated frontend assets (can change frequently)
custom_components/hacs/hacs_frontend/static/

# HACS frontend build artifacts
custom_components/hacs/hacs_frontend/frontend_latest/

# HACS frontend ES5 build artifacts
custom_components/hacs/hacs_frontend/frontend_es5/

# HA runtime lock
.ha_run.lock

# Local backup folders/files
backup-*/
backup-*.yaml

# Python caches
__pycache__/
*.pyc

# HACS-managed frontend files (auto-updated)
www/community/
custom_components/hacs/hacs_frontend/

# JS deps
node_modules/
node_modules/.cache/

# OS files
.DS_Store
